generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  FINANCE
  MEMBER
}

enum DossierStatus {
  ACTIVE
  DORMANT
  ARCHIVED
  CANCELLED
}

enum BusinessPhase {
  PROSPECTION
  CLOSING
  LCA
  LCMP
  LCSC
  CHANTIER
  RECEPTION
}

enum MissionType {
  LCA
  LCMP
  LCSC
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Competence {
  ARCHITECTURE
  INTERIOR_ARCHITECTURE
  PROJECT_PILOTAGE
  MAITRE_OEUVRE
  RELEVE
  DESSINATEUR
  GESTION
  PROSPECTION
  CLOSING
  SAV
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum InvoiceType {
  MISSION
  TIME_BASED
  DEPOSIT
  INTERMEDIATE
  BALANCE
}

enum PaymentMethod {
  TRANSFER
  CARD
  CHEQUE
  CASH
  OTHER
}

enum ActivityEntityType {
  WORKSPACE
  CLIENT
  CONTACT
  DOSSIER
  TASK
  MILESTONE
  MISSION
  INVOICE
  PAYMENT
  ATTACHMENT
  USER
}

enum AttachmentEntityType {
  DOSSIER
  CLIENT
  CONTACT
  TASK
  MILESTONE
  INVOICE
  PAYMENT
}

model Workspace {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  currency    String          @default("EUR")
  locale      String          @default("fr-FR")
  timezone    String          @default("Europe/Paris")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  users       User[]
  memberships Membership[]
  clients     Client[]
  contacts    Contact[]
  dossiers    Dossier[]
  invoices    Invoice[]
  payments    Payment[]
  activities  ActivityEvent[]
  attachments Attachment[]
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  passwordHash   String?
  avatarUrl      String?
  isActive       Boolean         @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspaceId    String?
  workspace      Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  memberships    Membership[]
  accounts       Account[]
  sessions       Session[]
  timeEntries    TimeEntry[]
  createdTasks   Task[]          @relation("TaskCreator")
  assignedTasks  Task[]          @relation("TaskAssignee")
  activities     ActivityEvent[]
  createdInvoices Invoice[]      @relation("InvoiceCreator")
}

model Membership {
  id          String    @id @default(cuid())
  role        UserRole
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspaceId String
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId, role])
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Client {
  id             String       @id @default(cuid())
  workspaceId     String
  name           String
  legalName       String?
  clientCode      String?
  email          String?
  phone          String?
  website        String?
  vatNumber      String?
  siren          String?
  billingAddress String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dossiers       Dossier[]
  contacts       Contact[]

  @@unique([workspaceId, clientCode])
  @@index([workspaceId, name])
}

model Contact {
  id           String         @id @default(cuid())
  workspaceId   String
  clientId      String?
  firstName    String
  lastName      String
  roleLabel     String?
  email        String?
  phone        String?
  mobilePhone   String?
  notes        String?
  isPrimary     Boolean       @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client       Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  dossierLinks DossierContact[]

  @@index([workspaceId, lastName, firstName])
  @@index([clientId])
}

model Dossier {
  id                    String            @id @default(cuid())
  workspaceId            String
  clientId               String
  reference             String
  title                 String
  description           String?
  status                DossierStatus     @default(ACTIVE)
  phase                 BusinessPhase
  priority              Int               @default(2)
  city                  String?
  postalCode            String?
  country               String?           @default("France")
  addressLine1          String?
  addressLine2          String?
  projectLabel          String?
  startDate             DateTime?
  closingDate           DateTime?
  chantierStartDate     DateTime?
  receptionDate         DateTime?
  archivedAt            DateTime?
  cancelledAt           DateTime?
  notes                 String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  workspace             Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client                Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  contacts              DossierContact[]
  residenceInfo         ResidenceInfo?
  chantierInfo          ChantierInfo?
  adminInfo             AdminInfo?
  tasks                 Task[]
  milestones            Milestone[]
  missions              MissionFee[]
  timeEntries           TimeEntry[]
  invoices              Invoice[]
  payments              Payment[]
  activities            ActivityEvent[]
  attachments           Attachment[]

  @@unique([workspaceId, reference])
  @@index([workspaceId, status, phase])
  @@index([clientId])
}

model DossierContact {
  id         String   @id @default(cuid())
  dossierId   String
  contactId   String
  roleLabel   String?
  isPrimary   Boolean  @default(false)
  createdAt  DateTime @default(now())
  dossier    Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([dossierId, contactId])
  @@index([contactId])
}

model ResidenceInfo {
  id                   String   @id @default(cuid())
  dossierId            String   @unique
  operationName        String?
  typology             String?
  lotCount             Int?
  surfaceSquareMeters  Decimal? @db.Decimal(10, 2)
  levelsCount          Int?
  isOccupied           Boolean?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  dossier              Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
}

model ChantierInfo {
  id                   String   @id @default(cuid())
  dossierId            String   @unique
  siteName             String?
  addressLine1         String?
  addressLine2         String?
  postalCode           String?
  city                 String?
  accessNotes          String?
  safetyNotes          String?
  expectedStartDate    DateTime?
  expectedEndDate      DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  dossier              Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
}

model AdminInfo {
  id                    String   @id @default(cuid())
  dossierId             String   @unique
  permitReference       String?
  permitFiledAt         DateTime?
  permitGrantedAt       DateTime?
  insurancePolicy       String?
  projectBudgetAmount   Decimal? @db.Decimal(12, 2)
  estimatedWorksAmount  Decimal? @db.Decimal(12, 2)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  dossier               Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
}

model Task {
  id               String      @id @default(cuid())
  workspaceId       String
  dossierId         String
  title            String
  description      String?
  status           TaskStatus  @default(TODO)
  dueDate          DateTime?
  completedAt      DateTime?
  priority         Int         @default(2)
  createdByUserId   String?
  assignedToUserId  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  dossier          Dossier     @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  createdBy        User?       @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedTo       User?       @relation("TaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([dossierId, status, dueDate])
  @@index([workspaceId, status])
}

model Milestone {
  id             String          @id @default(cuid())
  workspaceId     String
  dossierId       String
  title          String
  description    String?
  status         MilestoneStatus @default(PLANNED)
  dueDate        DateTime?
  completedAt    DateTime?
  phase          BusinessPhase?
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  dossier        Dossier         @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([dossierId, status, dueDate])
  @@index([workspaceId, dueDate])
}

model MissionFee {
  id                  String      @id @default(cuid())
  dossierId            String
  type                MissionType
  feeAmount           Decimal?    @db.Decimal(12, 2)
  estimatedHours      Decimal?    @db.Decimal(8, 2)
  hourlyRate          Decimal?    @db.Decimal(10, 2)
  startedAt           DateTime?
  completedAt         DateTime?
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  dossier             Dossier     @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  timeEntries         TimeEntry[]
  invoiceLines        InvoiceLine[]

  @@unique([dossierId, type])
  @@index([type])
}

model TimeEntry {
  id                 String      @id @default(cuid())
  workspaceId         String
  dossierId           String
  missionFeeId        String?
  userId              String?
  date               DateTime
  minutes            Int
  competence         Competence
  note               String?
  billable           Boolean     @default(true)
  hourlyValue        Decimal?    @db.Decimal(10, 2)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  dossier            Dossier     @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  missionFee         MissionFee? @relation(fields: [missionFeeId], references: [id], onDelete: SetNull)
  user               User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([dossierId, date])
  @@index([workspaceId, competence, date])
  @@index([missionFeeId])
}

model Invoice {
  id               String        @id @default(cuid())
  workspaceId       String
  dossierId         String
  createdByUserId   String?
  invoiceNo        String
  type             InvoiceType
  status           InvoiceStatus @default(DRAFT)
  issueDate        DateTime?
  sentAt           DateTime?
  dueDate          DateTime?
  paidAt           DateTime?
  currency         String        @default("EUR")
  label            String
  notes            String?
  subtotalAmount   Decimal       @db.Decimal(12, 2)
  vatAmount        Decimal       @db.Decimal(12, 2)
  totalAmount      Decimal       @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dossier          Dossier       @relation(fields: [dossierId], references: [id], onDelete: Restrict)
  createdBy        User?         @relation("InvoiceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines            InvoiceLine[]
  paymentAllocations PaymentAllocation[]
  attachments      Attachment[]
  activities       ActivityEvent[]

  @@unique([workspaceId, invoiceNo])
  @@index([dossierId, status])
  @@index([workspaceId, issueDate])
}

model InvoiceLine {
  id            String      @id @default(cuid())
  invoiceId      String
  missionFeeId   String?
  label         String
  description   String?
  quantity      Decimal     @db.Decimal(10, 2)
  unitPrice     Decimal     @db.Decimal(10, 2)
  vatRate       Decimal     @db.Decimal(5, 2) @default(20.00)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  invoice       Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  missionFee    MissionFee? @relation(fields: [missionFeeId], references: [id], onDelete: SetNull)

  @@index([invoiceId, sortOrder])
  @@index([missionFeeId])
}

model Payment {
  id               String              @id @default(cuid())
  workspaceId       String
  dossierId         String?
  receivedAt       DateTime            @default(now())
  amount           Decimal             @db.Decimal(12, 2)
  method           PaymentMethod       @default(TRANSFER)
  reference        String?
  payerName        String?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dossier          Dossier?            @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  allocations      PaymentAllocation[]
  attachments      Attachment[]
  activities       ActivityEvent[]

  @@index([workspaceId, receivedAt])
  @@index([dossierId])
}

model PaymentAllocation {
  id         String   @id @default(cuid())
  paymentId   String
  invoiceId   String
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([paymentId, invoiceId])
  @@index([invoiceId])
}

model ActivityEvent {
  id             String             @id @default(cuid())
  workspaceId     String
  actorUserId     String?
  dossierId       String?
  invoiceId       String?
  paymentId       String?
  entityType     ActivityEntityType
  entityId       String
  action         String
  description    String
  payload        Json?
  createdAt      DateTime           @default(now())
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser      User?              @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  dossier        Dossier?           @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  invoice        Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment        Payment?           @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([dossierId, createdAt])
  @@index([invoiceId, createdAt])
}

model Attachment {
  id             String               @id @default(cuid())
  workspaceId     String
  dossierId       String?
  invoiceId       String?
  paymentId       String?
  entityType     AttachmentEntityType
  entityId       String
  fileName       String
  mimeType       String
  fileSize       Int
  storageKey     String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dossier        Dossier?             @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  invoice        Invoice?             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment        Payment?             @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([workspaceId, entityType, entityId])
  @@index([dossierId])
  @@index([invoiceId])
}
