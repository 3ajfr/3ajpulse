# Database — PostgreSQL connection string
# Required for Prisma migrations, seed, and runtime
DATABASE_URL="postgresql://user:password@localhost:5432/3ajpulse?schema=public"

# Auth — NextAuth.js / Auth.js v5
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Set to true when deploying behind a proxy (Vercel, etc.)
AUTH_TRUST_HOST="true"

# Base URL of the application
# Optional on Vercel when AUTH_TRUST_HOST=true (URL is inferred automatically).
# Set explicitly when using a custom domain in production.
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"
